{
    "name": "gpt-pos/backend",
    "description": "Laravel backend for GPT POS",
    "type": "project",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0",
        "laravel/sanctum": "^4.0",
        "laravel/tinker": "^2.8"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "sailphp/sail": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "scripts": {
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "test": "phpunit"
    }
}
